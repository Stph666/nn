              <geom type="box" size="0.11 0.05 0.025" pos="0 0 -0.025" rgba="0.3 0.3 0.3 1"/>
            </body>
          </body>
        </body>
      </body>
    </body>

    <!--二号机器人 r2 红色 右半场-->
    <body name="r2_base" pos="0 0 0">
      <joint name="r2_slide_x" type="slide" axis="1 0 0"/>
      <joint name="r2_slide_y" type="slide" axis="0 1 0"/>
      <body name="r2_torso" pos="0 0 1.1">
        <geom type="capsule" fromto="0 0 0 0 0 -0.32" size="0.12" rgba="0.9 0.3 0.3 1"/>
        <body name="r2_head" pos="0 0 0.22"><geom type="sphere" size="0.11" rgba="0.8 0.6 0.4 1"/></body>
        <body name="r2_lsh" pos="-0.14 0 0">
          <joint name="r2_j_larm" type="hinge" axis="1 0 0" range="-0.7 0.7"/>
          <geom type="capsule" fromto="0 0 0 0 0 -0.36" size="0.042" rgba="0.5 0.5 0.5 1"/>
        </body>
        <body name="r2_rsh" pos="0.14 0 0">
          <joint name="r2_j_rarm" type="hinge" axis="1 0 0" range="-0.7 0.7"/>
          <geom type="capsule" fromto="0 0 0 0 0 -0.36" size="0.042" rgba="0.5 0.5 0.5 1"/>
        </body>
        <body name="r2_lhip" pos="-0.11 0 -0.32">
          <joint name="r2_left_hip" type="hinge" axis="1 0 0" range="-0.2 0.2"/>
          <geom type="capsule" fromto="0 0 0 0 0 -0.42" size="0.055" rgba="0.5 0.5 0.5 1"/>
          <body name="r2_lknee" pos="0 0 -0.42">
            <joint name="r2_left_knee" type="hinge" axis="1 0 0" range="0 0"/>
            <geom type="capsule" fromto="0 0 0 0 0 -0.42" size="0.052" rgba="0.5 0.5 0.5 1"/>
            <body name="r2_lank" pos="0 0 -0.42">
              <joint name="r2_left_ankle" type="hinge" axis="1 0 0" range="-0.2 0.2"/>
              <geom type="box" size="0.11 0.05 0.025" pos="0 0 -0.025" rgba="0.3 0.3 0.3 1"/>
            </body>
          </body>
        </body>
        <body name="r2_rhip" pos="0.11 0 -0.32">
          <joint name="r2_right_hip" type="hinge" axis="1 0 0" range="-0.2 0.2"/>
          <geom type="capsule" fromto="0 0 0 0 0 -0.42" size="0.055" rgba="0.5 0.5 0.5 1"/>
          <body name="r2_rknee" pos="0 0 -0.42">
            <joint name="r2_right_knee" type="hinge" axis="1 0 0" range="0 0"/>
            <geom type="capsule" fromto="0 0 0 0 0 -0.42" size="0.052" rgba="0.5 0.5 0.5 1"/>
            <body name="r2_rank" pos="0 0 -0.42">
              <joint name="r2_right_ankle" type="hinge" axis="1 0 0" range="-0.2 0.2"/>
              <geom type="box" size="0.11 0.05 0.025" pos="0 0 -0.025" rgba="0.3 0.3 0.3 1"/>
            </body>
          </body>
        </body>
      </body>
    </body>
  </worldbody>
</mujoco>